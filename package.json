{
  "name": "@vaughnbeckett/vite-plugin-import-url-content",
  "type": "module",
  "version": "0.1.11",
  "description": "Vite plugin template",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pkgroll",
    "dev": "pnpm run build -- --watch",
    "example:install": "pnpm -C example install",
    "example:dev": "pnpm run build -- --watch && pnpm -C example run dev",
    "example:build": "pnpm run build -- --watch && pnpm -C example run build",
    "lint": "eslint \"**/*.{vue,ts,js}\"",
    "release": "npx bumpp --commit --tag --push && npm publish",
    "typecheck": "vue-tsc --noEmit",
    "up": "taze major -r -I"
  },
  "peerDependencies": {
    "vite": ">=3.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.18.1",
    "eslint": "^9.3.0",
    "eslint-plugin-format": "^0.1.1",
    "sitemap-ts": "^1.10.1",
    "taze": "^0.18.0",
    "esbuild": "^0.28.0",
    "@types/node": "^22.0.0",
    "vite": "^6.0.0",
    "pkgroll": "^2.27.0",
    "typescript": "^5.0.0"
  }
}
